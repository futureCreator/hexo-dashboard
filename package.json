{
  "name": "hexo-dashboard",
  "version": "0.1.19",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 4000 -H 127.0.0.1",
    "lint": "next lint",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop hexo-dashboard",
    "pm2:restart": "pm2 restart hexo-dashboard",
    "pm2:delete": "pm2 delete hexo-dashboard",
    "pm2:logs": "pm2 logs hexo-dashboard",
    "deploy": "NEXT_PUBLIC_BASE_PATH=/proxy/hexo npm run build && npm run pm2:restart"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@google-analytics/data": "^5.2.1",
    "@uiw/react-codemirror": "^4.25.7",
    "framer-motion": "^11.18.2",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-d3-cloud": "^1.0.6",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
